# State-management implementation to mount at runtime.
#   'query' = TanStack Query + Zustand (Implementation 1)
#   'saga'  = Redux Toolkit + Redux Saga (Implementation 2)
VITE_STATE_MODE='query'

# Base URL of the FastAPI backend (REST; also the origin for the WebSocket).
VITE_API_BASE_URL='http://localhost:8000'
